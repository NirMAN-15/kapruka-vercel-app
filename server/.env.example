# ==============================================================
# Kapruka AI Shopping Agent Backend Configuration
# ==============================================================

# Server port
PORT=5000

# Kapruka MCP Server URL
KAPRUKA_MCP_URL=https://mcp.kapruka.com/mcp

# 1. Gemini API Keys (comma-separated list for automatic failover)
GEMINI_API_KEY=your_gemini_api_key_here,another_key_here

# 2. Groq API Keys (comma-separated list for automatic failover)
GROQ_API_KEY=your_groq_api_key_here,another_key_here

# 3. Kimi API Keys (Moonshot AI - comma-separated list)
KIMI_API_KEY=your_kimi_api_key_here

# 4. GLM API Keys (Zhipu AI - comma-separated list)
GLM_API_KEY=your_glm_api_key_here

# 5. Anthropic API Key (Claude fallback)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
